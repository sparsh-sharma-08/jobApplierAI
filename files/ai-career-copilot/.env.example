# AI Career Copilot - Environment Variables
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────
# LLM Configuration (for resume generation)
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
# For local LLMs (e.g., Ollama), set:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DATABASE_URL=sqlite:///./data/career_copilot.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/career_copilot

# ─────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────
DAILY_LIMIT=20
OUTPUT_DIR=./data/resumes
API_BASE=http://localhost:8000
